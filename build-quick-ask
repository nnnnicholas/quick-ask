#!/bin/zsh
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
APP_NAME="Quick Ask"
BUNDLE_ID="app.quickask.mac"
APP_DIR="$HOME/Applications/${APP_NAME}.app"
BIN_DIR="${APP_DIR}/Contents/MacOS"
RES_DIR="${APP_DIR}/Contents/Resources"
PLIST_PATH="${APP_DIR}/Contents/Info.plist"
LAUNCH_AGENT="$HOME/Library/LaunchAgents/${BUNDLE_ID}.plist"
SKIP_LAUNCH_AGENT="${QUICK_ASK_SKIP_LAUNCH_AGENT:-0}"
LAUNCH_DOMAIN="gui/$(id -u)"
LEGACY_AGENT_LABELS=(
  "com.nicholas.quickask"
  "com.nicholas.quick-ask"
)
LEGACY_AGENT_PATHS=(
  "$HOME/Library/LaunchAgents/com.nicholas.quickask.plist"
  "$HOME/Library/LaunchAgents/com.nicholas.quick-ask.plist"
)

mkdir -p "$BIN_DIR" "$RES_DIR" "$HOME/Applications" "$HOME/Library/LaunchAgents"

pkill -f "${APP_DIR}/Contents/MacOS/${APP_NAME}" >/dev/null 2>&1 || true

xcrun swiftc \
  -O \
  -parse-as-library \
  -framework SwiftUI \
  -framework AppKit \
  -framework Carbon \
  "${ROOT}/QuickAskApp.swift" \
  -o "${BIN_DIR}/${APP_NAME}"

cp "${ROOT}/quick_ask_backend.py" "${RES_DIR}/quick_ask_backend.py"
cp "${ROOT}/quick_ask_shared.py" "${RES_DIR}/quick_ask_shared.py"
chmod +x "${BIN_DIR}/${APP_NAME}" "${RES_DIR}/quick_ask_backend.py" "${RES_DIR}/quick_ask_shared.py"

cat > "$PLIST_PATH" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleDevelopmentRegion</key>
  <string>en</string>
  <key>CFBundleExecutable</key>
  <string>Quick Ask</string>
  <key>CFBundleIdentifier</key>
  <string>${BUNDLE_ID}</string>
  <key>CFBundleInfoDictionaryVersion</key>
  <string>6.0</string>
  <key>CFBundleName</key>
  <string>Quick Ask</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>CFBundleShortVersionString</key>
  <string>1.0</string>
  <key>CFBundleVersion</key>
  <string>1</string>
  <key>LSUIElement</key>
  <true/>
  <key>NSHighResolutionCapable</key>
  <true/>
</dict>
</plist>
PLIST

cat > "$LAUNCH_AGENT" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${BUNDLE_ID}</string>
  <key>ProgramArguments</key>
  <array>
    <string>${BIN_DIR}/${APP_NAME}</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ProcessType</key>
  <string>Interactive</string>
</dict>
</plist>
PLIST

for label in "${LEGACY_AGENT_LABELS[@]}"; do
  launchctl bootout "gui/$(id -u)/${label}" >/dev/null 2>&1 || true
done

for agent_path in "${LEGACY_AGENT_PATHS[@]}"; do
  rm -f "$agent_path"
done

if [[ "$SKIP_LAUNCH_AGENT" != "1" ]]; then
  if launchctl print "${LAUNCH_DOMAIN}/${BUNDLE_ID}" >/dev/null 2>&1; then
    launchctl kickstart -k "${LAUNCH_DOMAIN}/${BUNDLE_ID}"
  else
    launchctl bootstrap "${LAUNCH_DOMAIN}" "$LAUNCH_AGENT"
    launchctl kickstart -k "${LAUNCH_DOMAIN}/${BUNDLE_ID}"
  fi
else
  launchctl bootout "${LAUNCH_DOMAIN}" "$LAUNCH_AGENT" >/dev/null 2>&1 || true
  echo "Skipped LaunchAgent bootstrap because QUICK_ASK_SKIP_LAUNCH_AGENT=1"
fi

echo "Installed ${APP_NAME} at ${APP_DIR}"
